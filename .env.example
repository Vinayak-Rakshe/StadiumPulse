# StadiumPulse Environment Variables
# Copy this file to server/.env and fill in the values

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection String (e.g. MongoDB Atlas)
MONGO_URI=mongodb+srv://.../stadiumpulse

# JSON Web Token Secret
JWT_SECRET=stadiumpulse_secret_key_placeholder

# Backend Port
PORT=5000
